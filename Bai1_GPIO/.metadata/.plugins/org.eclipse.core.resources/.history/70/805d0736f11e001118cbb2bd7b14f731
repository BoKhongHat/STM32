//Cấu hình chân PA0 của Led Green trên Kit ở chế đọ Output

static void Led_Init(void) {
	//Khai báo biến thuộc kiểu duwxlieeuj struct GPIO
	GPIO_InitTypeDef GPIO_InitStructure;

	//Cấp xung Clock hoạt động cho Port A
	RCC_AHB1PeriphClockCmd (LED_GPIO_ClOCK_EN, ENALBE);

	//Cấu hình các thông số cho GPIO: PIN, Mode,Speed, OType, PuPd
	GPIO_InitStructure.GPIO_Pin = 	LED_GPIO_PIN;
	GPIO_InitStructure.GPIO_Mode = 	GPIO_Mode_OUT;
	GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
	GPIO_InitStructure.GPIO_OType = GPIO_OType_PP; //Chế độ đẩy kéo Push Pull
	GPIO_InitStructure.GPIO_PuPd = 	GPIO_PuPd_UP; //Trạng thái ban đầu là kéo lên

	//Khởi tạo các giá trị sử dụng hàm GPIO_Init
	GPIO_Init (LED_GPIO_PORT, &GPIO_InitStructure);
}

