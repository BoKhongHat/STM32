//Cấu hinh chân PB3 của nút nhấn B2 trên Kit ở chế độ INPUT
static void ButtonB2_Init(void) {
	//Khai báo biến thuộc kiểu duwxlieeuj struct GPIO
	GPIO_InitTypeDef GPIO_InitStructure;

	//Cấp xung Clock hoạt động cho Port A
	RCC_AHB1PeriphClockCmd (BUTTON_GPIO_CLOCK_EN, ENALBE);

