//Viết chương trình đảo trạng thái đầu ra của Led Red trên Kit
//mở rộng,sơ đồ chân của buzzer(PC9 và nút nhấn B5(PB3)trên mạch, LEd Red (PB13)


#include <stdint.h>
#include <stm32f401re_gpio.h>
#include <stm32f401re_rcc.h>

#define	HIGH						0
#define BTN_PRESS					HIGH

//define Logic GPIO PIN
#define GPIO_PIN_SET 				1
#define GPIO_PIN_RESET 				0
#define GPIO_PIN_LOW 				0
#define GPIO_PIN_HIGH 				1

//Define GPIO Pin
#define LEDRED_GPIO_PORT 			GPIOB
#define LEDRED_GPIO_PIN 			GPIO_Pin_13
#define LEDRED_PIN 					13
#define LEDREDControl_SetClock 		RCC_AHB1Periph_GPIOB

#define BUTTON_GPIO_PORT 			GPIOB
#define BUTTON_GPIO_PIN 			GPIO_Pin_3
#define BUTTON_B2_PIN 				3
#define BUTTONControl_SetClock 		RCC_AHB1Periph_GPIOB

void delay() {
	for (uint32_t i = 0; i < 500000; i++);
}

//Cấu hình chân PB13 của Led_Red trên Kit ở chế đọ Output
static void Led_Init(void) {
	//Khai báo biến thuộc kiểu dữ liệu struct GPIO
	GPIO_InitTypeDef GPIO_InitStructure;

	//kết nối clock cho GPIOB
	RCC_AHB1PeriphClockCmd (LEDREDControl_SetClock, ENABLE);

	//Chọn chân sử dụng với chức năng điều khiển Led
	GPIO_InitStructure.GPIO_Pin = LEDRED_GPIO_PIN;

	//Chọn chân điều khiển led ở chế độ Output
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_OUT;

	//Tốc độ xử lí trên chân là 50MHz
	GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;

	//Chọn chế độ là đẩy kéo Push Pull
	GPIO_InitStructure.GPIO_OType = GPIO_OType_PP;

	//Trạng thái ban đầu trên chân là kéo xuống GND Pull Dowm
	GPIO_InitStructure.GPIO_PuPd = GPIO_PuPd_DOWN;

	//Khởi tạo tất cả các giá trị = hàm GPIO_Init
	// với đối số truyền vào GPIOB và GPIO_InitStructure
	GPIO_Init (LEDRED_GPIO_PORT, &GPIO_InitStructure);
}

//Cấu hình chân PB3 của nút nhấn B2 ở chế độ Input

static void Button_Init(void) {
	//Khai báo biến thuộc kiểu dữ liệu struct GPIO
	GPIO_InitTypeDef GPIO_InitStructure;

	//Cấp xung Clock hoạt động cho Port B
	RCC_AHB1PeriphClockCmd (BUTTONControl_SetClock, ENABLE);

	//Chọn chân sử dụng làm chức năng nút ấn
	GPIO_InitStructure.GPIO_Pin = BUTTON_GPIO_PIN;

	//Chọn chế độ trên chân GPIO là Input.
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN;

	//Tốc độ xử lí trên chân là 50MHz
	GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;


	//Trạng thái Kéo trở lên nguồn +3.3V (Pull Up)
	GPIO_InitStructure.GPIO_PuPd = GPIO_PuPd_UP;

	//Khởi tạo tất cả các giá trị = hàm GPIO_Init
	// với đối số truyền vào GPIOB và GPIO_InitStructure
	GPIO_Init (BUTTON_GPIO_PORT, &GPIO_InitStructure);

}

//Xây dựng hàm điều khiển LED RED
static void LedControl_SetStatus (GPIO_TypeDef * GPIOx, uint16_t GPIO_PIN, uint8_t Status) {
		//Set bit in BSRR Registers
		if (Status == GPIO_PIN_SET)
		{
			GPIOx->BSRRL |= 1 << GPIO_PIN;
		}
		//Reset bit in BSRR Registers
		if (Status == GPIO_PIN_RESET)
		{
			GPIOx->BSRRH |= 1 << GPIO_PIN;
		}
	}

//Xây dựng hàm đọc giá trị nút ấn
static
uint8_t ButtonRead_Status (GPIO_TypeDef * GPIOx, uint32_t GPIO_PIN) {
	uint32_t Read_Pin;

	//Read bit in IDR Registers
	Read_Pin = (GPIOx->IDR) >>GPIO_PIN;
	Read_Pin = Read_Pin & 0x01;

	return Read_Pin;
}

//Trong While(1), thực hiện thuật toán đảo trạng thái Led Red khi nút B2 trên
//Kit được nhấn
//Tạo và sd hàm delay để chống rung khi nhấn nút
int main(void)
{
	uint8_t status = 1;
		Led_Init();
		Button_Init();
		while (1) {

			if (ButtonRead_Status(BUTTON_GPIO_PORT, BUTTON_GPIO_PIN) == BTN_PRESS) {
				delay();
				status++;
			}
			if (status % 2 == 0) {
				delay();
				LedControl_SetStatus(LEDRED_GPIO_PORT, LEDRED_GPIO_PIN, GPIO_PIN_HIGH);
			} else {
				delay();
				LedControl_SetStatus(LEDRED_GPIO_PORT, LEDRED_GPIO_PIN, GPIO_PIN_LOW);
			}
		}
		return 0;
}
